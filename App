    const files = Array.from(e.target.files);
    files.forEach(file => {
      const reader = new FileReader();
      reader.onload = (ev) => {
        setUploadedImages(prev => [...prev, { url: ev.target.result, name: file.name, type: file.type }]);
      };
      reader.readAsDataURL(file);
    });
  };

  const handleGoalAnswer = (qId, answer) => {
    const next = { ...goalAnswers, [qId]: answer };
    setGoalAnswers(next);
    if (signupStep < goalQuestions.length - 1) {
      setTimeout(() => setSignupStep(s => s + 1), 300);
    } else {
      setTimeout(() => { setView("app"); setActiveTab("home"); }, 400);
    }
  };

  const handleCheckInAnswer = (qId, answer) => {
    setCheckInAnswers(prev => ({ ...prev, [qId]: answer }));
  };


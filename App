              {goalQuestions.map((_, i) => <div key={i} className={`step-dot ${i <= signupStep ? "active" : ""}`} />)}
            </div>
            <p style={{color: COLORS.muted, fontSize: 13, marginBottom: 6}}>Question {signupStep + 1} of {goalQuestions.length}</p>
            <h2>{q.question}</h2>
            {q.options.map(opt => (
              <button key={opt} className={`option-btn ${goalAnswers[q.id] === opt ? "selected" : ""}`}
                onClick={() => handleGoalAnswer(q.id, opt)}>
                {goalAnswers[q.id] === opt ? "✓ " : ""}{opt}
              </button>
            ))}
          </div>
        </div>
      </div>
    );
  }

  // ── VIDEO CALL ──
  if (inCall) return (
    <div className="tf-app">
      <style>{css}</style>
      <div className="call-screen">
        <div className="call-main">
          <div style={{display:"flex",flexDirection:"column",alignItems:"center"}}>
            <div className="call-avatar">TF</div>
            <div className="call-name">TrueForm Coaching</div>
            <div className="call-status">● Connected · 0:42</div>
          </div>
          <div className="self-preview">
            <span style={{fontSize:32}}>👤</span>
          </div>
        </div>
        <div className="call-controls">
          <button className="call-btn mute">🎙️</button>
          <button className="call-btn mute">📷</button>
          <button className="call-btn end" onClick={() => setInCall(false)}>📵</button>
          <button className="call-btn mute">💬</button>
        </div>
      </div>
    </div>
  );

  // ── MAIN APP ──
  const renderHome = () => (
    <>
      <div className="greeting-card">
        <h3>GOOD MORNING{signupData.name ? `, ${signupData.name.split(" ")[0].toUpperCase()}` : ""}! 👋</h3>
        <p>Day 8 of your journey. Keep pushing — you're building something real.</p>
      </div>

      {!checkInDone ? (
        <div className="checkin-banner" onClick={() => setShowCheckIn(true)}>
          <div>
            <h4>Daily Check-in</h4>
            <p>2 min · Tell me how your day went</p>
          </div>
          <span style={{fontSize:28}}>📋</span>
        </div>
      ) : (
        <div className="checkin-done">
          <span style={{fontSize:36}}>✅</span>
          <div>
            <div style={{fontWeight:600,marginBottom:2}}>Check-in Complete!</div>
            <div style={{fontSize:13,color:COLORS.muted}}>Great job logging in today.</div>
          </div>
        </div>
      )}

      <div className="stat-row">
        <div className="stat-card">
          <div className="val">8</div>
          <div className="lbl">Day Streak 🔥</div>
        </div>
        <div className="stat-card">
          <div className="val">5/7</div>
          <div className="lbl">Workouts This Week</div>
        </div>
        <div className="stat-card">
          <div className="val">68%</div>
          <div className="lbl">Goal Progress</div>
          <div className="prog-bar"><div className="prog-fill" style={{width:"68%"}} /></div>
        </div>
        <div className="stat-card">
          <div className="val">12</div>
          <div className="lbl">Check-ins Logged</div>
        </div>
      </div>

      <div className="section-title">YOUR GOAL</div>
      <div className="goal-tag">{goalAnswers.primary || "Build Muscle"}</div>
      <div className="prog-bar" style={{height:8,marginBottom:8}}><div className="prog-fill" style={{width:"68%"}} /></div>
      <p style={{fontSize:13,color:COLORS.muted,marginBottom:24}}>68% complete · {goalAnswers.timeline || "3 Months"} program</p>
    </>
  );

  const renderCheckin = () => (
    <div className="modal-overlay" onClick={() => setShowCheckIn(false)}>
      <div className="modal-sheet" onClick={e => e.stopPropagation()}>
        <div className="step-indicator">
          {checkInQuestions.map((_, i) => <div key={i} className={`step-dot ${i <= checkInStep ? "active" : ""}`} />)}
        </div>
        <h3>{checkInQuestions[checkInStep].question}</h3>
        {checkInQuestions[checkInStep].type === "emoji" && (
          <div className="emoji-row">
            {checkInQuestions[checkInStep].emoji.map((e, i) => (
              <button key={i} className={`emoji-opt ${checkInAnswers[checkInQuestions[checkInStep].id] === i ? "selected" : ""}`}
                onClick={() => handleCheckInAnswer(checkInQuestions[checkInStep].id, i)}>{e}</button>
            ))}
          </div>
        )}
        {checkInQuestions[checkInStep].type === "options" && (
          checkInQuestions[checkInStep].options.map(opt => (
            <button key={opt} className={`option-btn ${checkInAnswers[checkInQuestions[checkInStep].id] === opt ? "selected" : ""}`}
              onClick={() => handleCheckInAnswer(checkInQuestions[checkInStep].id, opt)}>{opt}</button>
          ))
        )}
        {checkInQuestions[checkInStep].type === "text" && (
          <textarea className="text-input-field" rows={3} placeholder="Type here..."
            value={checkInAnswers[checkInQuestions[checkInStep].id] || ""}
            onChange={e => handleCheckInAnswer(checkInQuestions[checkInStep].id, e.target.value)} />
        )}
        <div className="modal-nav">
          {checkInStep > 0 && <button className="btn-ghost" onClick={() => setCheckInStep(s => s - 1)}>← Back</button>}
          <button className="btn-primary" style={{flex:1}} onClick={advanceCheckIn}>
            {checkInStep < checkInQuestions.length - 1 ? "Next →" : "Submit ✓"}
          </button>
        </div>
      </div>
    </div>
  );

  const renderMedia = () => (
    <>
      <div className="section-title" style={{marginBottom:16}}>SHARE PROGRESS PHOTOS</div>
      <input type="file" ref={fileInputRef} accept="image/*,video/*" multiple style={{display:"none"}} onChange={handleFileUpload} />
      <div className="upload-zone" onClick={() => fileInputRef.current.click()}>
        <span style={{fontSize:40}}>📸</span>
        <p>Tap to upload photos or videos<br/><span style={{fontSize:12,color:COLORS.accent}}>Share your progress with your coach</span></p>
      </div>
      {uploadedImages.length > 0 && (
        <>
          <div className="section-title" style={{marginBottom:12}}>UPLOADED</div>
          <div className="image-grid">
            {uploadedImages.map((img, i) => (
              <div className="image-thumb" key={i}>
                {img.type.startsWith("image") ? (
                  <img src={img.url} alt={img.name} />
                ) : (
                  <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:8}}>
                    <span style={{fontSize:36}}>🎥</span>
                    <span style={{fontSize:11,color:COLORS.muted}}>Video</span>
                  </div>
                )}
                <div className="img-label">{img.name.length > 16 ? img.name.slice(0,14)+"…" : img.name}</div>
              </div>
            ))}
          </div>
        </>
      )}
      {uploadedImages.length === 0 && (
        <div style={{textAlign:"center",padding:"40px 0",color:COLORS.muted,fontSize:14}}>
          No photos shared yet.<br/>Upload your first progress photo!
        </div>
      )}
    </>
  );

  const renderChat = () => (
    <>
      <div className="chat-header">
        <div className="chat-avatar">TF</div>
        <div style={{flex:1}}>
          <div style={{fontWeight:600}}>TrueForm Coaching</div>
          <div style={{fontSize:12,color:COLORS.accent}}>● Online</div>
        </div>
        <button className="video-btn" onClick={() => setInCall(true)}>📹</button>
      </div>
      <div className="chat-messages">
        {messages.map((m, i) => (
          <div key={i} className={`msg ${m.from === "coach" ? "from-coach" : "from-client"}`}>
            <div className="msg-bubble">{m.text}</div>
            <div className="msg-time">{m.time}</div>
          </div>
        ))}
      </div>
      <div className="chat-input-row">
        <input className="chat-input" placeholder="Message your coach..." value={chatMsg}
          onChange={e => setChatMsg(e.target.value)}
          onKeyDown={e => e.key === "Enter" && handleSendMessage()} />
        <button className="send-btn" onClick={handleSendMessage}>➤</button>
      </div>
    </>
  );

  const renderProgress = () => (
    <>
      <div className="section-title">GOAL OVERVIEW</div>
      <div className="goal-tag">{goalAnswers.primary || "Build Muscle"} · {goalAnswers.timeline || "3 Months"}</div>
      {[
        { label: "Workout Consistency", value: 71 },
        { label: "Nutrition Adherence", value: 58 },
        { label: "Sleep Quality", value: 80 },
        { label: "Mindset Score", value: 65 },
        { label: "Overall Progress", value: 68 },
      ].map(p => (
        <div className="prog-item" key={p.label}>
          <div className="prog-item-header">
            <span>{p.label}</span>
            <em>{p.value}%</em>
          </div>
          <div className="prog-bar"><div className="prog-fill" style={{width:`${p.value}%`}} /></div>
        </div>
      ))}
      <div className="section-title" style={{marginTop:24}}>RECENT CHECK-INS</div>
      {["Mon","Tue","Wed","Thu","Fri"].map((d, i) => (
        <div key={d} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"10px 0",borderBottom:`1px solid ${COLORS.border}`}}>
          <span style={{color:COLORS.muted,fontSize:13,width:40}}>{d}</span>
          <span style={{fontSize:20}}>{"😊😊🙂😊🤩"[i]}</span>
          <span style={{fontSize:13,color:COLORS.muted}}>{["Workout ✓","Rest Day","Workout ✓","Workout ✓","Workout ✓"][i]}</span>
          <span style={{fontSize:13,color:COLORS.accent}}>✓</span>
        </div>
      ))}
    </>
  );

  // ── COACH DASHBOARD ──
  const renderCoach = () => {
    if (selectedClient) {
      const c = selectedClient;
      return (
        <>
          <button className="back-btn" onClick={() => setSelectedClient(null)}>← Back to Clients</button>
          <div style={{display:"flex",alignItems:"center",gap:16,marginBottom:24}}>
            <div className="client-avatar" style={{width:60,height:60,fontSize:20}}>{c.avatar}</div>
            <div>
              <div style={{fontWeight:700,fontSize:18}}>{c.name}</div>
              <div style={{fontSize:13,color:COLORS.muted}}>{c.goal}</div>
            </div>
            <div style={{marginLeft:"auto"}}>
              <button className="btn-outline" style={{padding:"10px 18px",fontSize:14}} onClick={() => setInCall(true)}>📹 Call</button>
            </div>
          </div>
          <div className="stat-row">
            <div className="stat-card"><div className="val">{c.streak}</div><div className="lbl">Day Streak</div></div>
            <div className="stat-card"><div className="val">{c.progress}%</div><div className="lbl">Progress</div><div className="prog-bar"><div className="prog-fill" style={{width:`${c.progress}%`}} /></div></div>
          </div>
          <div className="section-title">LAST CHECK-IN</div>
          {[
            {label:"Mood", val:"😊 Great"},
            {label:"Sleep", val:"7–8 hrs"},
            {label:"Nutrition", val:"Good"},
            {label:"Workout", val:"Completed ✓"},
            {label:"Win", val:"Hit a new PR on bench!"},
            {label:"Challenge", val:"Meal prepping on weekends"},
          ].map(item => (
            <div key={item.label} style={{display:"flex",justifyContent:"space-between",padding:"10px 0",borderBottom:`1px solid ${COLORS.border}`,fontSize:14}}>
              <span style={{color:COLORS.muted}}>{item.label}</span>
              <span>{item.val}</span>
            </div>
          ))}
          <div className="section-title" style={{marginTop:24}}>SEND MESSAGE</div>
          <div className="chat-input-row">
            <input className="chat-input" placeholder="Send a message to client..." value={chatMsg}
              onChange={e => setChatMsg(e.target.value)}
              onKeyDown={e => e.key === "Enter" && handleSendMessage()} />
            <button className="send-btn" onClick={handleSendMessage}>➤</button>
          </div>
        </>
      );
    }
    return (
      <>
        <div className="stat-row" style={{marginBottom:20}}>
          <div className="stat-card"><div className="val">{mockClients.length}</div><div className="lbl">Active Clients</div></div>
          <div className="stat-card"><div className="val">2</div><div className="lbl">Check-ins Today</div></div>
        </div>
        <div className="section-title">YOUR CLIENTS</div>
        {mockClients.map(c => (
          <div className="client-card" key={c.id} onClick={() => setSelectedClient(c)}>
            <div className="client-avatar">{c.avatar}</div>
            <div className="client-info">
              <h4>{c.name}</h4>
              <p>{c.goal} · Last check-in: {c.lastCheckin}</p>
              <div className="prog-bar" style={{marginTop:8}}><div className="prog-fill" style={{width:`${c.progress}%`}} /></div>
            </div>
            <div className="streak-badge">🔥 {c.streak}</div>
          </div>
        ))}
      </>
    );
  };

  const tabs = role === "coach"
    ? [{ id: "clients", label: "Clients", icon: "👥" }, { id: "messages", label: "Messages", icon: "💬" }]
    : [
        { id: "home", label: "Home", icon: "🏠" },
        { id: "checkin", label: "Progress", icon: "📊" },
        { id: "media", label: "Photos", icon: "📸" },
        { id: "messages", label: "Coach", icon: "💬" },
      ];

  return (
    <div className="tf-app">
      <style>{css}</style>
      <div className="app-shell">
        <div className="top-bar">
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <div className="logo-mark" style={{width:36,height:36,borderRadius:10}}><span style={{fontSize:16}}>TF</span></div>
            <span className="bebas" style={{fontSize:20}}>TRUEFORM</span>
          </div>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            {role === "client" && (
              <div style={{background:`rgba(200,246,90,0.1)`,border:`1px solid ${COLORS.accent}44`,borderRadius:999,padding:"4px 12px",fontSize:12,color:COLORS.accent}}>
                🔥 8 Day Streak
              </div>
            )}
            <div className="avatar-sm">{signupData.name ? signupData.name[0] : role === "coach" ? "C" : "U"}</div>
          </div>
        </div>

        <div className="content-area">
          {role === "coach"
            ? activeTab === "clients" ? renderCoach() : renderChat()
            : activeTab === "home" ? renderHome()
            : activeTab === "checkin" ? renderProgress()
            : activeTab === "media" ? renderMedia()
            : renderChat()
          }
        </div>

        <nav className="bottom-nav">
          {tabs.map(t => (
            <button key={t.id} className={`nav-item ${activeTab === t.id ? "active" : ""}`} onClick={() => setActiveTab(t.id)}>
              <span className="nav-icon">{t.icon}</span>
              {t.label}
            </button>
          ))}
        </nav>

        {showCheckIn && renderCheckin()}
      </div>
    </div>
  );
}

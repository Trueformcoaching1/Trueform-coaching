  </div>
</div>

<!-- ═══ CHECK-IN MODAL ═══ -->
<div class="modal-overlay" id="checkin-modal">
  <div class="modal-sheet">
    <div class="step-dots" id="ci-dots"></div>
    <h3 id="ci-question"></h3>
    <div id="ci-body"></div>
    <div class="modal-nav">
      <button class="btn-ghost" id="ci-back" onclick="ciBack()">← Back</button>
      <button class="btn-primary" style="flex:1;" id="ci-next" onclick="ciNext()">Next →</button>
    </div>
  </div>
</div>

<!-- ═══ VIDEO CALL SCREEN ═══ -->
<div id="call-screen">
  <div class="call-main">
    <div style="display:flex;flex-direction:column;align-items:center;">
      <div class="call-big-av" id="call-av">TF</div>
      <div class="call-name" id="call-name">TrueForm Coaching</div>
      <div class="call-status" id="call-status">● Connecting...</div>
    </div>
    <div class="self-preview">👤</div>
  </div>
  <div class="call-controls">
    <button class="call-btn ctrl" id="mute-btn" onclick="toggleMute()">🎙️</button>
    <button class="call-btn ctrl">📷</button>
    <button class="call-btn end" onclick="endCall()">📵</button>
    <button class="call-btn ctrl">💬</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════
//  STATE
// ══════════════════════════════════════
let state = {
  role: null,        // 'client' | 'coach'
  name: '',
  goals: {},
  checkinDone: false,
  checkinCount: 12,
  streak: 8,
  checkInAnswers: {},
  uploadedImages: [],
  clientMessages: [
    {from:'coach', text:"Hey! Great check-in yesterday. Your consistency is showing 🔥", time:"9:00 AM"},
    {from:'client', text:"Thanks! Feeling way more energized this week", time:"9:15 AM"},
    {from:'coach', text:"That's the work paying off. Let's push harder this week 💪", time:"9:17 AM"},
  ],
  coachMessages: [],
  selectedClient: null,
  callTimer: null,
  callSeconds: 0,
  muted: false,
};

const CLIENTS = [
  {id:1, name:"Jordan M.", goal:"Build Muscle", streak:7, lastCheckin:"Today", avatar:"JM", progress:68,
   checkin:{mood:"😊 Great", sleep:"7–8 hrs", nutrition:"Good", workout:"Completed ✓", win:"Hit a new PR on bench!", challenge:"Meal prepping on weekends"}},
  {id:2, name:"Aisha K.", goal:"Lose Weight", streak:14, lastCheckin:"Yesterday", avatar:"AK", progress:45,
   checkin:{mood:"🙂 Okay", sleep:"5–6 hrs", nutrition:"Okay", workout:"Partial", win:"Drank 3L of water!", challenge:"Late-night snacking"}},
  {id:3, name:"Tyler R.", goal:"Improve Mindset", streak:3, lastCheckin:"Today", avatar:"TR", progress:82,
   checkin:{mood:"🤩 Amazing", sleep:"8+ hrs", nutrition:"Excellent", workout:"Completed ✓", win:"Meditated for 20 mins", challenge:"Managing work stress"}},
];

const GOAL_QUESTIONS = [
  {id:"primary", q:"What's your primary goal?", opts:["Lose Weight","Build Muscle","Improve Mindset","Increase Energy","Overall Wellness"]},
  {id:"timeline", q:"What's your timeline?", opts:["1 Month","3 Months","6 Months","1 Year","Ongoing"]},
  {id:"commitment", q:"How many days/week can you commit?", opts:["1–2 Days","3–4 Days","5–6 Days","Every Day"]},
  {id:"obstacles", q:"Biggest obstacle right now?", opts:["Motivation","Time","Knowledge","Accountability","Stress"]},
];
let goalStep = 0;

const CHECKIN_QUESTIONS = [
  {id:"mood", q:"How are you feeling today?", type:"emoji", opts:["😞","😐","🙂","😊","🤩"]},
  {id:"sleep", q:"How many hours did you sleep?", type:"opts", opts:["<5 hrs","5–6 hrs","7–8 hrs","8+ hrs"]},
  {id:"nutrition", q:"How was your nutrition today?", type:"opts", opts:["Poor","Okay","Good","Excellent"]},
  {id:"workout", q:"Did you complete your workout?", type:"opts", opts:["Not yet","Partial","Yes!","Rest day"]},
  {id:"win", q:"What's one win from today?", type:"text"},
  {id:"challenge", q:"Anything you struggled with?", type:"text"},
];
let ciStep = 0;

// ══════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════
function show(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(screenId);
  el.classList.add('active');
  if(screenId === 'app') el.style.display = 'block';
}

function showTab(tabId, btn) {
  document.querySelectorAll('.tab-pane').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tabId).classList.add('active');
  const nav = state.role === 'coach' ? document.getElementById('coach-nav') : document.getElementById('client-nav');
  nav.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  if(tabId === 'clients') renderClientList();
  if(tabId === 'progress') renderProgress();
  if(tabId === 'chat') renderClientChat();
  if(tabId === 'coach-messages') renderCoachMsgList();
}

// ══════════════════════════════════════
//  AUTH
// ══════════════════════════════════════
function doSignup() {
  const name = document.getElementById('su-name').value.trim();
  const email = document.getElementById('su-email').value.trim();
  if(!name || !email){ showToast('Please fill in all fields'); return; }
  state.name = name;
  state.role = 'client';
  goalStep = 0;
  renderGoalQuestion();
  show('goals');
}

function doLogin() {
  const email = document.getElementById('li-email').value.trim();
  if(!email){ showToast('Please enter your email'); return; }
  state.name = email.split('@')[0];
  state.role = 'client';
  launchApp();
}

function coachLogin() {
  state.role = 'coach';
  state.name = 'Coach';
  launchApp();
}

function launchApp() {
  // set UI
  document.getElementById('user-av').textContent = state.name[0].toUpperCase();
  if(state.role === 'coach') {
    document.getElementById('streak-chip').style.display = 'none';
    document.getElementById('client-nav').classList.add('hidden');
    document.getElementById('coach-nav').classList.remove('hidden');
    renderClientList();
    show('app');
    showTab('clients', document.querySelector('#coach-nav .nav-btn'));
  } else {
    document.getElementById('greet-name').textContent = `GOOD MORNING, ${state.name.toUpperCase()}! 👋`;
    document.getElementById('home-goal-tag').textContent = state.goals.primary || 'Build Muscle';
    document.getElementById('home-timeline').textContent = state.goals.timeline || '3 Months';
    document.getElementById('prog-goal-tag').textContent = `${state.goals.primary||'Build Muscle'} · ${state.goals.timeline||'3 Months'}`;
    renderProgress();
    renderClientChat();
    show('app');
    showTab('home', document.querySelector('#client-nav .nav-btn'));
  }
}

// ══════════════════════════════════════
//  GOAL QUESTIONS
// ══════════════════════════════════════
function renderGoalQuestion() {
  const q = GOAL_QUESTIONS[goalStep];
  // dots
  const dots = document.getElementById('goal-dots');
  dots.innerHTML = GOAL_QUESTIONS.map((_,i) => `<div class="step-dot ${i<=goalStep?'on':''}"></div>`).join('');
  document.getElementById('goal-counter').textContent = `Question ${goalStep+1} of ${GOAL_QUESTIONS.length}`;
  document.getElementById('goal-q').textContent = q.q;
  const opts = document.getElementById('goal-opts');
  opts.innerHTML = q.opts.map(o =>
    `<button class="opt-btn ${state.goals[q.id]===o?'sel':''}" onclick="selectGoal('${q.id}','${o}')">${state.goals[q.id]===o?'✓ ':''}${o}</button>`
  ).join('');
}

function selectGoal(id, val) {
  state.goals[id] = val;
  if(goalStep < GOAL_QUESTIONS.length - 1) {
    goalStep++;
    setTimeout(renderGoalQuestion, 250);
  } else {
    launchApp();
  }
}

// ══════════════════════════════════════
//  CHECK-IN MODAL
// ══════════════════════════════════════
function openCheckin() {
  ciStep = 0;
  state.checkInAnswers = {};
  renderCiStep();
  document.getElementById('checkin-modal').classList.add('open');
}

function renderCiStep() {
  const q = CHECKIN_QUESTIONS[ciStep];
  const dots = document.getElementById('ci-dots');
  dots.innerHTML = CHECKIN_QUESTIONS.map((_,i) => `<div class="step-dot ${i<=ciStep?'on':''}"></div>`).join('');
  document.getElementById('ci-question').textContent = q.q;
  document.getElementById('ci-back').style.display = ciStep === 0 ? 'none' : '';
  document.getElementById('ci-next').textContent = ciStep < CHECKIN_QUESTIONS.length-1 ? 'Next →' : 'Submit ✓';

  const body = document.getElementById('ci-body');
  if(q.type === 'emoji') {
    body.innerHTML = `<div class="emoji-row">${q.opts.map((e,i) =>
      `<button class="emoji-opt ${state.checkInAnswers[q.id]===i?'sel':''}" onclick="ciAnswer('${q.id}',${i},this)">${e}</button>`
    ).join('')}</div>`;
  } else if(q.type === 'opts') {
    body.innerHTML = q.opts.map(o =>
      `<button class="opt-btn ${state.checkInAnswers[q.id]===o?'sel':''}" onclick="ciAnswer('${q.id}','${o}',this)">${state.checkInAnswers[q.id]===o?'✓ ':''}${o}</button>`
    ).join('');
  } else {
    body.innerHTML = `<textarea class="textarea-field" rows="3" placeholder="Type here..." oninput="ciAnswer('${q.id}',this.value)">${state.checkInAnswers[q.id]||''}</textarea>`;
  }
}

function ciAnswer(id, val, btn) {
  state.checkInAnswers[id] = val;
  // update styles
  const q = CHECKIN_QUESTIONS[ciStep];
  if(q.type === 'emoji') {
    document.querySelectorAll('.emoji-opt').forEach((b,i) => b.classList.toggle('sel', i === val));
  } else if(q.type === 'opts') {
    document.querySelectorAll('#ci-body .opt-btn').forEach(b => {
      b.classList.remove('sel');
      b.textContent = b.textContent.replace('✓ ','');
    });
    if(btn){ btn.classList.add('sel'); btn.textContent = '✓ ' + btn.textContent; }
  }
}

function ciNext() {
  if(ciStep < CHECKIN_QUESTIONS.length - 1) {
    ciStep++;
    renderCiStep();
  } else {
    document.getElementById('checkin-modal').classList.remove('open');
    state.checkinDone = true;
    state.checkinCount++;
    state.streak++;
    document.getElementById('checkin-count').textContent = state.checkinCount;
    document.getElementById('streak-val').textContent = state.streak;
    document.getElementById('streak-chip').textContent = `🔥 ${state.streak} Day Streak`;
    document.getElementById('checkin-area').innerHTML = `
      <div class="done-banner fadein">
        <span style="font-size:36px;">✅</span>
        <div><div style="font-weight:600;margin-bottom:2px;">Check-in Complete!</div>
        <div style="font-size:13px;color:var(--muted);">Great job logging in today.</div></div>
      </div>`;
    showToast('Check-in submitted! 🎉');
  }
}

function ciBack() {
  if(ciStep > 0){ ciStep--; renderCiStep(); }
}

// ══════════════════════════════════════
//  PROGRESS TAB
// ══════════════════════════════════════
function renderProgress() {
  const bars = [
    {label:"Workout Consistency", val:71},
    {label:"Nutrition Adherence", val:58},
    {label:"Sleep Quality", val:80},
    {label:"Mindset Score", val:65},
    {label:"Overall Progress", val:68},
  ];
  document.getElementById('prog-bars').innerHTML = bars.map(b => `
    <div class="prog-item">
      <div class="prog-item-hdr"><span>${b.label}</span><em>${b.val}%</em></div>
      <div class="prog-bar"><div class="prog-fill" style="width:${b.val}%"></div></div>
    </div>`).join('');

  const days = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const moods = ['😊','😊','🙂','😊','🤩','😐','😊'];
  const workouts = ['Workout ✓','Rest Day','Workout ✓','Workout ✓','Workout ✓','Rest Day','Workout ✓'];
  document.getElementById('history-list').innerHTML = days.map((d,i) => `
    <div class="history-row">
      <span class="day">${d}</span>
      <span style="font-size:20px;">${moods[i]}</span>
      <span style="color:var(--muted);font-size:13px;">${workouts[i]}</span>
      <span class="status">✓</span>
    </div>`).join('');
}

// ══════════════════════════════════════
//  PHOTOS
// ══════════════════════════════════════
function handleUpload(e) {
  const files = Array.from(e.target.files);
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = ev => {
      state.uploadedImages.push({url:ev.target.result, name:file.name, type:file.type});
      renderImages();
    };
    reader.readAsDataURL(file);
  });
  showToast('Photo uploaded! 📸');
}

function renderImages() {
  const grid = document.getElementById('img-grid');
  const title = document.getElementById('uploaded-title');
  if(state.uploadedImages.length === 0){ title.style.display='none'; grid.innerHTML=''; return; }
  title.style.display='block';
  grid.innerHTML = state.uploadedImages.map(img => `
    <div class="img-thumb">
      ${img.type.startsWith('image')
        ? `<img src="${img.url}" alt="${img.name}"/>`
        : `<div style="display:flex;flex-direction:column;align-items:center;gap:6px;"><span class="video-thumb-icon">🎥</span><span style="font-size:11px;color:var(--muted);">Video</span></div>`}
      <div class="img-label">${img.name.length>16?img.name.slice(0,14)+'…':img.name}</div>
    </div>`).join('');
}

// ══════════════════════════════════════
//  CHAT (CLIENT SIDE)
// ══════════════════════════════════════
function renderClientChat() {
  const box = document.getElementById('client-messages');
  box.innerHTML = state.clientMessages.map(m => `
    <div class="msg ${m.from}">
      <div class="bubble">${m.text}</div>
      <div class="msg-time">${m.time}</div>
    </div>`).join('');
  box.scrollTop = box.scrollHeight;
}

function sendClientMsg() {
  const inp = document.getElementById('client-chat-input');
  const txt = inp.value.trim();
  if(!txt) return;
  state.clientMessages.push({from:'client', text:txt, time:'Now'});
  inp.value = '';
  renderClientChat();
  setTimeout(() => {
    state.clientMessages.push({from:'coach', text:"Got it! Keep up the amazing work 💪", time:'Now'});
    renderClientChat();
  }, 1200);
}

// ══════════════════════════════════════
//  COACH DASHBOARD
// ══════════════════════════════════════
function renderClientList() {
  document.getElementById('client-list').innerHTML = CLIENTS.map(c => `
    <div class="client-card" onclick="openClientDetail(${c.id})">
      <div class="cl-av">${c.avatar}</div>
      <div class="cl-info">
        <h4>${c.name}</h4>
        <p>${c.goal} · Last: ${c.lastCheckin}</p>
        <div class="prog-bar" style="margin-top:8px;"><div class="prog-fill" style="width:${c.progress}%"></div></div>
      </div>
      <div class="streak-badge">🔥 ${c.streak}</div>
    </div>`).join('');
}

function openClientDetail(id) {
  const c = CLIENTS.find(x => x.id === id);
  state.selectedClient = c;
  document.getElementById('detail-av').textContent = c.avatar;
  document.getElementById('detail-name').textContent = c.name;
  document.getElementById('detail-goal').textContent = c.goal;
  document.getElementById('detail-streak').textContent = c.streak;
  document.getElementById('detail-prog').textContent = c.progress + '%';
  document.getElementById('detail-prog-fill').style.width = c.progress + '%';
  document.getElementById('detail-call-btn').onclick = () => startCall(c.name, c.avatar);

  const rows = [
    {lbl:'Mood', val: c.checkin.mood},
    {lbl:'Sleep', val: c.checkin.sleep},
    {lbl:'Nutrition', val: c.checkin.nutrition},
    {lbl:'Workout', val: c.checkin.workout},
    {lbl:'Win', val: c.checkin.win},
    {lbl:'Challenge', val: c.checkin.challenge},
  ];
  document.getElementById('detail-checkin').innerHTML = rows.map(r => `
    <div class="checkin-detail-row"><span class="lbl">${r.lbl}</span><span>${r.val}</span></div>`).join('');

  document.getElementById('coach-messages').innerHTML = '';
  state.coachMessages = [];

  showTab('client-detail');
}

function sendCoachMsg() {
  const inp = document.getElementById('coach-chat-input');
  const txt = inp.value.trim();
  if(!txt) return;
  state.coachMessages.push({from:'coach', text:txt, time:'Now'});
  inp.value = '';
  const box = document.getElementById('coach-messages');
  box.innerHTML = state.coachMessages.map(m => `
    <div class="msg ${m.from}">
      <div class="bubble">${m.text}</div>
      <div class="msg-time">${m.time}</div>
    </div>`).join('');
  box.scrollTop = box.scrollHeight;
  showToast('Message sent ✓');
}

function renderCoachMsgList() {
  document.getElementById('coach-msg-list').innerHTML = CLIENTS.map(c => `
    <div class="client-card" onclick="openClientDetail(${c.id});showTab('client-detail')">
      <div class="cl-av">${c.avatar}</div>
      <div class="cl-info">
        <h4>${c.name}</h4>
        <p style="color:var(--muted);font-size:13px;">Tap to message</p>
      </div>
      <span style="font-size:18px;">💬</span>
    </div>`).join('');
}

// ══════════════════════════════════════
//  VIDEO CALL
// ══════════════════════════════════════
function startCall(name, av) {
  document.getElementById('call-av').textContent = av || 'TF';
  document.getElementById('call-name').textContent = name || 'TrueForm Coaching';
  document.getElementById('call-status').textContent = '● Connecting...';
  document.getElementById('call-screen').classList.add('active');
  state.callSeconds = 0;
  state.muted = false;
  document.getElementById('mute-btn').textContent = '🎙️';
  setTimeout(() => {
    document.getElementById('call-status').textContent = '● Connected · 0:00';
    state.callTimer = setInterval(() => {
      state.callSeconds++;
      const m = Math.floor(state.callSeconds/60);
      const s = String(state.callSeconds%60).padStart(2,'0');
      document.getElementById('call-status').textContent = `● Connected · ${m}:${s}`;
    }, 1000);
  }, 1500);
}

function endCall() {
  clearInterval(state.callTimer);
  document.getElementById('call-screen').classList.remove('active');
  showToast('Call ended');
}

function toggleMute() {
  state.muted = !state.muted;
  document.getElementById('mute-btn').textContent = state.muted ? '🔇' : '🎙️';
}

// ══════════════════════════════════════
//  TOAST
// ══════════════════════════════════════
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ══════════════════════════════════════
//  CLOSE MODAL ON OVERLAY CLICK
// ══════════════════════════════════════
document.getElementById('checkin-modal').addEventListener('click', function(e){
  if(e.target === this) this.classList.remove('open');
});

// Init progress on load
renderProgress();
renderImages();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>TrueForm Coaching</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #0a0a0f;
  --surface: #111118;
  --card: #16161f;
  --border: #1e1e2e;
  --accent: #c8f65a;
  --accent-dim: #9bbf3e;
  --gold: #f0c060;
  --text: #f0f0f0;
  --muted: #6b6b80;
  --danger: #ff5566;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
.bebas{font-family:'Bebas Neue',sans-serif;letter-spacing:1px;}
.hidden{display:none!important;}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh;}
.screen.active{display:flex;flex-direction:column;}

/* ── LANDING ── */
#landing{align-items:center;justify-content:center;padding:32px 24px;position:relative;overflow:hidden;text-align:center;}
.land-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 50% at 50% 0%,#1a2a0a,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 90%,#0a1a20,transparent 60%);pointer-events:none;}
.grid{position:absolute;inset:0;background-image:linear-gradient(rgba(200,246,90,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,246,90,.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;}
.logo-mark{width:72px;height:72px;border-radius:20px;background:var(--accent);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;box-shadow:0 0 40px rgba(200,246,90,.35);}
.logo-mark span{font-family:'Bebas Neue';font-size:32px;color:#0a0a0f;}
#landing h1{font-family:'Bebas Neue';font-size:clamp(52px,12vw,96px);line-height:.9;letter-spacing:2px;margin-bottom:16px;}
#landing h1 em{color:var(--accent);font-style:normal;}
#landing > p{color:var(--muted);font-size:15px;max-width:380px;line-height:1.7;margin:0 auto 40px;}
.btn-row{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;}
.pills{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:44px;}
.pill{background:rgba(255,255,255,.04);border:1px solid var(--border);padding:7px 16px;border-radius:999px;font-size:13px;color:var(--muted);}

/* ── BUTTONS ── */
.btn-primary{background:var(--accent);color:#0a0a0f;border:none;padding:14px 32px;border-radius:12px;font-family:'Bebas Neue';font-size:18px;letter-spacing:1px;cursor:pointer;transition:all .2s;}
.btn-primary:hover{background:var(--accent-dim);transform:translateY(-1px);}
.btn-outline{background:transparent;color:var(--accent);border:1.5px solid var(--accent);padding:14px 32px;border-radius:12px;font-family:'Bebas Neue';font-size:18px;letter-spacing:1px;cursor:pointer;transition:all .2s;}
.btn-outline:hover{background:rgba(200,246,90,.08);}
.btn-ghost{background:transparent;color:var(--muted);border:1.5px solid var(--border);padding:12px 22px;border-radius:10px;font-size:14px;cursor:pointer;transition:all .2s;font-family:'DM Sans';}
.btn-ghost:hover{border-color:var(--muted);color:var(--text);}
.btn-full{width:100%;margin-top:8px;}
.btn-sm{padding:9px 18px;font-size:14px;border-radius:9px;}

/* ── AUTH ── */
#signup,#login,#goals{align-items:center;justify-content:center;padding:24px;}
.auth-card{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:36px;width:100%;max-width:420px;}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:24px;}
.auth-logo .lm{width:40px;height:40px;border-radius:11px;background:var(--accent);display:flex;align-items:center;justify-content:center;}
.auth-logo .lm span{font-family:'Bebas Neue';font-size:18px;color:#0a0a0f;}
.auth-logo strong{font-family:'Bebas Neue';font-size:22px;}
.auth-card h2{font-family:'Bebas Neue';font-size:34px;margin-bottom:4px;}
.auth-card .sub{color:var(--muted);font-size:14px;margin-bottom:28px;}
.field{margin-bottom:16px;}
.field label{display:block;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
.field input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-size:15px;outline:none;transition:border-color .2s;font-family:'DM Sans';}
.field input:focus{border-color:var(--accent);}
.auth-link{text-align:center;margin-top:16px;color:var(--muted);font-size:13px;}
.auth-link a{color:var(--accent);cursor:pointer;text-decoration:none;}
.step-dots{display:flex;gap:6px;margin-bottom:22px;}
.step-dot{flex:1;height:3px;border-radius:999px;background:var(--border);transition:background .3s;}
.step-dot.on{background:var(--accent);}
.opt-btn{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:13px 16px;text-align:left;color:var(--text);font-size:15px;cursor:pointer;transition:all .2s;margin-bottom:10px;font-family:'DM Sans';}
.opt-btn:hover,.opt-btn.sel{border-color:var(--accent);background:rgba(200,246,90,.06);color:var(--accent);}

/* ── APP SHELL ── */
#app{position:relative;}
#app.active{display:block;min-height:100vh;}
.app-wrap{max-width:500px;margin:0 auto;display:flex;flex-direction:column;min-height:100vh;}
.top-bar{padding:18px 20px 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.top-bar .logo-row{display:flex;align-items:center;gap:10px;}
.top-bar .lm2{width:36px;height:36px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;}
.top-bar .lm2 span{font-family:'Bebas Neue';font-size:16px;color:#0a0a0f;}
.top-bar .brand{font-family:'Bebas Neue';font-size:20px;}
.top-bar .right{display:flex;align-items:center;gap:10px;}
.streak-chip{background:rgba(200,246,90,.12);border:1px solid rgba(200,246,90,.3);border-radius:999px;padding:4px 12px;font-size:12px;color:var(--accent);}
.user-av{width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#0a0a0f;cursor:pointer;flex-shrink:0;}
.content{flex:1;padding:20px;padding-bottom:100px;overflow-y:auto;}
.tab-pane{display:none;}
.tab-pane.active{display:block;}

/* ── BOTTOM NAV ── */
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:500px;background:rgba(17,17,24,.97);border-top:1px solid var(--border);display:flex;padding:12px 0 20px;backdrop-filter:blur(14px);z-index:100;}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;color:var(--muted);font-size:11px;border:none;background:none;transition:color .2s;font-family:'DM Sans';}
.nav-btn.active{color:var(--accent);}
.nav-icon{font-size:22px;line-height:1;}

/* ── HOME TAB ── */
.greet-card{background:linear-gradient(135deg,rgba(200,246,90,.14),rgba(200,246,90,.04));border:1px solid rgba(200,246,90,.3);border-radius:20px;padding:24px;margin-bottom:18px;}
.greet-card h3{font-family:'Bebas Neue';font-size:28px;color:var(--accent);}
.greet-card p{color:var(--muted);font-size:14px;margin-top:4px;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px;}
.stat-val{font-family:'Bebas Neue';font-size:36px;color:var(--accent);line-height:1;}
.stat-lbl{font-size:12px;color:var(--muted);margin-top:4px;}
.prog-bar{height:6px;background:var(--border);border-radius:999px;margin-top:8px;overflow:hidden;}
.prog-fill{height:100%;background:var(--accent);border-radius:999px;transition:width .5s;}
.sec-title{font-family:'Bebas Neue';font-size:18px;color:var(--muted);margin-bottom:12px;letter-spacing:1px;}
.checkin-banner{background:var(--accent);border-radius:16px;padding:20px;display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;cursor:pointer;border:none;width:100%;text-align:left;}
.checkin-banner h4{font-family:'Bebas Neue';font-size:22px;color:#0a0a0f;}
.checkin-banner p{font-size:13px;color:rgba(0,0,0,.55);margin-top:2px;}
.done-banner{background:var(--card);border:1px solid rgba(200,246,90,.35);border-radius:16px;padding:20px;display:flex;align-items:center;gap:16px;margin-bottom:18px;}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.82);display:flex;align-items:flex-end;z-index:200;opacity:0;pointer-events:none;transition:opacity .25s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-sheet{background:var(--card);border-radius:24px 24px 0 0;padding:32px 24px 44px;width:100%;max-width:500px;margin:0 auto;transform:translateY(40px);transition:transform .3s;}
.modal-overlay.open .modal-sheet{transform:translateY(0);}
.modal-sheet h3{font-family:'Bebas Neue';font-size:26px;margin-bottom:20px;}
.emoji-row{display:flex;justify-content:space-around;margin-bottom:8px;}
.emoji-opt{font-size:36px;cursor:pointer;padding:8px;border-radius:12px;border:2px solid transparent;transition:all .2s;background:none;}
.emoji-opt:hover,.emoji-opt.sel{border-color:var(--accent);background:rgba(200,246,90,.1);transform:scale(1.15);}
.textarea-field{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;color:var(--text);font-size:15px;font-family:'DM Sans';outline:none;resize:none;}
.textarea-field:focus{border-color:var(--accent);}
.modal-nav{display:flex;gap:10px;margin-top:24px;}

/* ── PROGRESS TAB ── */
.goal-tag{display:inline-block;background:rgba(200,246,90,.1);color:var(--accent);border:1px solid rgba(200,246,90,.3);padding:4px 14px;border-radius:999px;font-size:13px;margin-bottom:16px;}
.prog-item{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;margin-bottom:12px;}
.prog-item-hdr{display:flex;justify-content:space-between;margin-bottom:10px;}
.prog-item-hdr span{font-size:14px;font-weight:500;}
.prog-item-hdr em{color:var(--accent);font-style:normal;font-size:14px;}
.history-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border);font-size:14px;}
.history-row .day{color:var(--muted);width:36px;}
.history-row .status{color:var(--accent);}

/* ── PHOTOS TAB ── */
.upload-zone{border:2px dashed var(--border);border-radius:16px;padding:36px;display:flex;flex-direction:column;align-items:center;gap:12px;cursor:pointer;transition:all .2s;margin-bottom:16px;background:none;width:100%;}
.upload-zone:hover{border-color:var(--accent);background:rgba(200,246,90,.04);}
.upload-zone p{color:var(--muted);font-size:14px;text-align:center;pointer-events:none;}
.upload-zone .upload-hint{color:var(--accent);font-size:12px;}
.img-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.img-thumb{border-radius:12px;overflow:hidden;aspect-ratio:1;background:var(--surface);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);position:relative;}
.img-thumb img{width:100%;height:100%;object-fit:cover;}
.img-label{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.65);padding:6px 8px;font-size:11px;color:var(--muted);}
.video-thumb-icon{font-size:36px;}

/* ── CHAT TAB ── */
.chat-hdr{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.chat-av{width:44px;height:44px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#0a0a0f;flex-shrink:0;}
.chat-av.client{background:var(--surface);border:1px solid var(--border);color:var(--text);}
.online{font-size:12px;color:var(--accent);}
.vid-btn{width:42px;height:42px;border-radius:50%;background:var(--card);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;}
.messages{display:flex;flex-direction:column;gap:12px;margin-bottom:16px;min-height:200px;}
.msg{max-width:76%;}
.msg.coach{align-self:flex-start;}
.msg.client{align-self:flex-end;}
.bubble{padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.5;}
.coach .bubble{background:var(--card);border:1px solid var(--border);border-bottom-left-radius:4px;}
.client .bubble{background:var(--accent);color:#0a0a0f;border-bottom-right-radius:4px;}
.msg-time{font-size:11px;color:var(--muted);margin-top:3px;padding:0 4px;}
.client .msg-time{text-align:right;}
.chat-input-row{display:flex;gap:10px;align-items:center;}
.chat-input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:12px 18px;color:var(--text);font-size:14px;outline:none;font-family:'DM Sans';}
.chat-input:focus{border-color:var(--accent);}
.send-btn{width:44px;height:44px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}

/* ── COACH DASHBOARD ── */
.coach-stat-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:20px;}
.client-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:10px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:all .2s;}
.client-card:hover{border-color:rgba(200,246,90,.4);}
.cl-av{width:48px;height:48px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#0a0a0f;flex-shrink:0;}
.cl-info{flex:1;}
.cl-info h4{font-size:15px;font-weight:600;margin-bottom:2px;}
.cl-info p{font-size:12px;color:var(--muted);}
.streak-badge{background:rgba(200,246,90,.15);color:var(--accent);font-size:12px;padding:4px 10px;border-radius:999px;font-weight:600;white-space:nowrap;}
.back-btn{display:flex;align-items:center;gap:6px;color:var(--muted);font-size:14px;cursor:pointer;margin-bottom:20px;background:none;border:none;font-family:'DM Sans';}
.back-btn:hover{color:var(--text);}
.detail-header{display:flex;align-items:center;gap:16px;margin-bottom:24px;}
.detail-av{width:60px;height:60px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#0a0a0f;}
.checkin-detail-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:14px;}
.checkin-detail-row .lbl{color:var(--muted);}

/* ── VIDEO CALL ── */
#call-screen{position:fixed;inset:0;background:#000;z-index:500;display:none;flex-direction:column;}
#call-screen.active{display:flex;}
.call-main{flex:1;background:var(--surface);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;}
.call-big-av{width:100px;height:100px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue';font-size:42px;color:#0a0a0f;}
.call-name{font-family:'Bebas Neue';font-size:30px;margin-top:16px;}
.call-status{color:var(--accent);font-size:14px;margin-top:4px;}
.self-preview{position:absolute;bottom:20px;right:20px;width:100px;height:140px;background:var(--card);border-radius:16px;border:2px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:32px;}
.call-controls{background:rgba(0,0,0,.92);padding:24px;display:flex;justify-content:center;gap:20px;}
.call-btn{width:60px;height:60px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:24px;transition:transform .2s;}
.call-btn:hover{transform:scale(1.1);}
.call-btn.end{background:var(--danger);}
.call-btn.ctrl{background:var(--card);border:1px solid var(--border);}

/* ── TOAST ── */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--accent);color:#0a0a0f;padding:10px 22px;border-radius:999px;font-size:14px;font-weight:600;z-index:999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.fadein{animation:fadeIn .35s ease forwards;}
</style>
</head>
<body>

<!-- ═══ LANDING ═══ -->
<div id="landing" class="screen active">
  <div class="land-bg"></div>
  <div class="grid"></div>
  <div class="logo-mark"><span>TF</span></div>
  <h1 class="bebas">TRUEFORM<br/><em>COACHING</em></h1>
  <p>Transform your body, sharpen your mind, and show up as your best self — with a coach who's truly in your corner.</p>
  <div class="btn-row">
    <button class="btn-primary" onclick="show('signup')">Start Your Journey</button>
    <button class="btn-outline" onclick="coachLogin()">Coach Login</button>
  </div>
  <div class="pills">
    <div class="pill">✦ Daily Check-ins</div>
    <div class="pill">✦ Progress Tracking</div>
    <div class="pill">✦ Photo Updates</div>
    <div class="pill">✦ Video Calls</div>
    <div class="pill">✦ 1:1 Messaging</div>
  </div>
</div>

<!-- ═══ SIGN UP ═══ -->
<div id="signup" class="screen">
  <div class="auth-card fadein" style="margin:auto;">
    <div class="auth-logo">
      <div class="lm"><span>TF</span></div>
      <strong>TRUEFORM</strong>
    </div>
    <h2>Create Account</h2>
    <p class="sub">Start your transformation today</p>
    <div class="field"><label>Full Name</label><input id="su-name" placeholder="Your name" type="text"/></div>
    <div class="field"><label>Email</label><input id="su-email" placeholder="you@email.com" type="email"/></div>
    <div class="field"><label>Password</label><input id="su-pass" placeholder="••••••••" type="password"/></div>
    <button class="btn-primary btn-full" onclick="doSignup()">Continue →</button>
    <p class="auth-link">Already have an account? <a onclick="show('login')">Log in</a></p>
    <p class="auth-link" style="margin-top:6px;"><a onclick="show('landing')">← Back</a></p>
  </div>
</div>

<!-- ═══ LOGIN ═══ -->
<div id="login" class="screen">
  <div class="auth-card fadein" style="margin:auto;">
    <div class="auth-logo">
      <div class="lm"><span>TF</span></div>
      <strong>TRUEFORM</strong>
    </div>
    <h2>Welcome Back</h2>
    <p class="sub">Log in to your account</p>
    <div class="field"><label>Email</label><input id="li-email" placeholder="you@email.com" type="email"/></div>
    <div class="field"><label>Password</label><input id="li-pass" placeholder="••••••••" type="password"/></div>
    <button class="btn-primary btn-full" onclick="doLogin()">Log In →</button>
    <p class="auth-link">No account? <a onclick="show('signup')">Sign up</a></p>
    <p class="auth-link" style="margin-top:6px;"><a onclick="show('landing')">← Back</a></p>
  </div>
</div>

<!-- ═══ GOAL QUESTIONS ═══ -->
<div id="goals" class="screen">
  <div class="auth-card fadein" style="margin:auto;">
    <div class="step-dots" id="goal-dots"></div>
    <p style="color:var(--muted);font-size:13px;margin-bottom:6px;" id="goal-counter"></p>
    <h2 class="bebas" id="goal-q" style="font-size:26px;margin-bottom:20px;"></h2>
    <div id="goal-opts"></div>
  </div>
</div>

<!-- ═══ MAIN APP ═══ -->
<div id="app" class="screen">
  <div class="app-wrap">
    <div class="top-bar">
      <div class="logo-row">
        <div class="lm2"><span>TF</span></div>
        <span class="brand bebas">TRUEFORM</span>
      </div>
      <div class="right">
        <div class="streak-chip" id="streak-chip">🔥 8 Day Streak</div>
        <div class="user-av" id="user-av">U</div>
      </div>
    </div>

    <div class="content">
      <!-- HOME -->
      <div class="tab-pane active" id="tab-home">
        <div class="greet-card">
          <h3 id="greet-name">GOOD MORNING! 👋</h3>
          <p>Day 8 of your journey. Keep pushing — you're building something real.</p>
        </div>
        <div id="checkin-area">
          <button class="checkin-banner" onclick="openCheckin()">
            <div><h4>Daily Check-in</h4><p>2 min · Tell me how your day went</p></div>
            <span style="font-size:28px;">📋</span>
          </button>
        </div>
        <div class="stat-grid">
          <div class="stat-card"><div class="stat-val" id="streak-val">8</div><div class="stat-lbl">Day Streak 🔥</div></div>
          <div class="stat-card"><div class="stat-val">5/7</div><div class="stat-lbl">Workouts This Week</div></div>
          <div class="stat-card">
            <div class="stat-val">68%</div><div class="stat-lbl">Goal Progress</div>
            <div class="prog-bar"><div class="prog-fill" style="width:68%"></div></div>
          </div>

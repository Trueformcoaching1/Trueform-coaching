      <button class="nav-btn active" data-tab="clients" onclick="showTab('clients',this)"><span class="nav-icon">👥</span>Clients</button>
      <button class="nav-btn" data-tab="coach-messages" onclick="showTab('coach-messages',this)"><span class="nav-icon">💬</span>Messages</button>
